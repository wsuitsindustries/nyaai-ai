# NyaAI — LLM Provider Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# Provider: openai, groq, ollama, openrouter, together, github
LLM_PROVIDER=openai

# API key for your chosen provider (required for non-Ollama providers)
# In production, prefer setting this via environment variables or secrets manager
LLM_API_KEY=

# Base URL for the API (default: OpenAI)
LLM_BASE_URL=https://api.openai.com/v1

# Model name (e.g. gpt-4o-mini, llama-3.3-70b-versatile)
LLM_MODEL=gpt-4o-mini

# Generation settings
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# Embedding model (default: Xenova/gte-tiny — 22MB, fast ONNX)
EMBEDDING_MODEL=Xenova/gte-tiny
EMBEDDING_DIM=384

# Redis (optional — enables embedding cache across workers)
REDIS_URL=redis://localhost:6379/0

# Hugging Face token for faster model downloads (optional but recommended)
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=
